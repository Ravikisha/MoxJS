{
  "name": "@mfjs/cli",
  "version": "0.1.0",
  "description": "MFJS command-line tool: scaffold, dev, build, federation, SSR, deploy, and diagnostics for module federation workspaces.",
  "license": "MIT",
  "homepage": "https://github.com/anthropics/MFJS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/MFJS.git",
    "directory": "packages/cli"
  },
  "keywords": ["mfjs", "module-federation", "cli", "rspack", "scaffold"],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "mfjs": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "templates", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "commander": "^12.1.0",
    "@inquirer/prompts": "^6.0.1",
    "fs-extra": "^11.2.0",
    "kleur": "^4.1.5",
    "execa": "^9.5.3",
    "ws": "^8.18.3",
    "@mfjs/ssr": "workspace:*",
    "@mfjs/types": "workspace:*",
    "tree-kill": "^1.2.2",
    "chokidar": "^4.0.3"
  },
  "optionalDependencies": {
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "eslint": "^9.20.1",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.9",
    "@types/ws": "^8.5.4"
  }
}
