{
  "name": "@mfjs/state",
  "version": "0.1.0",
  "description": "Lightweight shared-state primitives for MFJS micro-frontends (Redux-style store + simple observable store).",
  "license": "MIT",
  "homepage": "https://github.com/anthropics/MFJS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/MFJS.git",
    "directory": "libs/state"
  },
  "keywords": ["mfjs", "module-federation", "state", "store", "micro-frontend"],
  "private": false,
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
