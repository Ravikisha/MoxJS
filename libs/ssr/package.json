{
  "name": "@mfjs/ssr",
  "version": "0.1.0",
  "description": "Server-side rendering primitives for MFJS: edge adapter, streaming, static export, state hydration.",
  "license": "MIT",
  "homepage": "https://github.com/anthropics/MFJS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/MFJS.git",
    "directory": "libs/ssr"
  },
  "keywords": ["mfjs", "module-federation", "ssr", "edge", "streaming", "react"],
  "private": false,
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./edge": { "types": "./dist/edge.d.ts", "import": "./dist/edge.js" },
    "./node": { "types": "./dist/node.d.ts", "import": "./dist/node.js" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mfjs/runtime": "workspace:*",
    "@mfjs/security": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
