{
  "name": "@mfjs/observability",
  "version": "0.1.0",
  "description": "Telemetry hooks for MFJS: error reporting, metrics, remote-load tracing, structured logger, Web Vitals.",
  "license": "MIT",
  "homepage": "https://github.com/anthropics/MFJS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/MFJS.git",
    "directory": "libs/observability"
  },
  "keywords": ["mfjs", "module-federation", "observability", "telemetry", "logging", "metrics"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": { "access": "public" },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
