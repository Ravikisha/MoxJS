{
  "name": "mfjs-example-ecommerce",
  "private": true,
  "type": "module",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "predev": "pnpm -C ../../packages/cli build && pnpm -C ../../libs/runtime build && pnpm -C ../../libs/ssr build",
    "prefederation": "pnpm -C ../../packages/cli build",
    "federation": "node ../../packages/cli/dist/index.js federation --dir .",
    "routes": "node ../../packages/cli/dist/index.js routes --dir .",
    "dev": "node ../../packages/cli/dist/index.js dev --dir .",
    "ssr:export": "node ../../packages/cli/dist/index.js ssr export --dir . --config mfjs.ssr.json",
    "test": "vitest run"
  }
}
